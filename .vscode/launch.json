{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug grammar-flow",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/grammar-flow",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
